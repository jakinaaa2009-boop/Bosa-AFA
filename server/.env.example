# --- Local ---
PORT=5050
# Required for stable logins across Railway restarts. If unset, the server generates one per boot (sessions reset).
JWT_SECRET=change-this-to-a-long-random-string

# MongoDB Atlas: Database → Connect → Drivers → copy SRV connection string.
# Replace <password>, set app name; add user with read/write on your DB.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/promo-site?retryWrites=true&w=majority

# Required when the React app is on Vercel: exact browser origin(s), comma-separated, no trailing slash.
# Example: https://bosa-afa.vercel.app
# If this does not match, the browser shows a CORS error (check Railway logs for [cors] Rejected Origin).
CLIENT_ORIGIN=http://localhost:5173

# Same public URL as Railway gives you (Settings → Networking → Public URL).
# No trailing slash. Used so JSON imageUrl fields work when the React app is on Vercel.
# Example: https://promo-api-production.up.railway.app
PUBLIC_URL=

# --- Railway ---
# Set all of the above as variables in Railway (omit PORT unless you need a fixed port).
# Atlas: Network Access → allow 0.0.0.0/0 (or Railway egress IPs) so the deploy can connect.
# Uploads live on disk under server/uploads — add a Railway Volume mounted at /app/uploads
# (or your service path + uploads) if you need files to survive redeploys.
